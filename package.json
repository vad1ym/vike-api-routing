{
  "name": "vike-api-router",
  "version": "0.1.9",
  "description": "File-based API routing for Vike — supports Hono, h3, and more",
  "type": "module",
  "license": "MIT",
  "author": "vad1ym",
  "repository": {
    "type": "git",
    "url": "https://github.com/vad1ym/vike-api-routing.git"
  },
  "homepage": "https://github.com/vad1ym/vike-api-routing#readme",
  "bugs": {
    "url": "https://github.com/vad1ym/vike-api-routing/issues"
  },
  "keywords": [
    "vike",
    "api",
    "router",
    "file-based",
    "hono",
    "h3",
    "vite",
    "ssr"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./lib/plugin/index.ts",
      "default": "./dist/plugin.js"
    },
    "./client": {
      "types": "./lib/client.ts",
      "default": "./dist/client.js"
    },
    "./config": {
      "types": "./lib/config.ts",
      "default": "./dist/config.js"
    },
    "./handlers": {
      "types": "./lib/handlers.ts",
      "default": "./dist/handlers.js"
    },
    "./proxy": {
      "types": "./lib/proxy.ts",
      "default": "./dist/proxy.js"
    },
    "./internal/routeAdapter": {
      "types": "./lib/middleware/routeAdapter.ts",
      "default": "./dist/internal/routeAdapter.js"
    },
    "./internal/rpcAdapter": {
      "types": "./lib/middleware/rpcAdapter.ts",
      "default": "./dist/internal/rpcAdapter.js"
    }
  },
  "files": [
    "lib",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "changelog": "changelogen",
    "changelog:dry": "changelogen --no-output",
    "release": "changelogen --release",
    "example:hono": "pnpm run build && pnpm --filter example-vike-api-router-hono dev",
    "example:hono:build": "pnpm run build && pnpm --filter example-vike-api-router-hono build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@universal-middleware/core": "^0.4.17",
    "changelogen": "^0.6.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vike": "^0.4.259",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@universal-middleware/core": ">=0.4.0",
    "vike": ">=0.4.259",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@universal-middleware/core": {
      "optional": true
    },
    "vike": {
      "optional": true
    }
  },
  "changelog": {
    "output": false,
    "types": {
      "chore": false
    }
  },
  "packageManager": "pnpm@10.11.0"
}
